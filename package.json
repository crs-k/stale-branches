{
  "name": "@crs-k/stale-branches",
  "version": "0.0.0",
  "private": true,
  "author": "Chris Kerins",
  "license": "MIT",
  "description": "Finds and deletes stale branches",
  "main": "lib/main.js",
  "homepage": "https://github.com/marketplace/actions/stale-branches",
  "bugs": {
    "url": "https://github.com/crs-k/stale-branches/issues"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write src/**/*.ts",
    "format-check": "prettier --check src/**/*.ts",
    "lint": "npm run npmpackagejsonlint . && npm run eslint",
    "eslint": "eslint src/**/*.ts",
    "npmpackagejsonlint": "npmPkgJsonLint .",
    "package": "esbuild lib/main.js --bundle --platform=node --conditions=import --outfile=dist/index.js --sourcemap",
    "test": "jest --coverage",
    "all": "npm run format && npm run lint && npm test && npm run build && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/crs-k/stale-branches.git"
  },
  "keywords": [
    "actions"
  ],
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "@octokit/types": "16.0.0",
    "@types/semver": "7.7.1",
    "assert": "2.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@types/jest": "29.5.14",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "esbuild": "0.28.0",
    "ansi-styles": "5.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-github": "5.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "jest": "29.7.0",
    "js-yaml": "4.1.1",
    "npm-package-json-lint": "9.0.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
